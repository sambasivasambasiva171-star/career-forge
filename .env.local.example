# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# NVIDIA NIM — https://build.nvidia.com
NVIDIA_NIM_API_KEY=nvapi-your-key-here
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# Model selection — stronger instruction-following models reduce rule
# violations and hallucination. Test candidates from the free catalog at
# https://build.nvidia.com/models (set on Vercel too):
#   openai/gpt-oss-120b     (recommended first test)
#   deepseek-ai/deepseek-v3.2 or newer
#   zai-org/glm-5 family
# NVIDIA_NIM_MODEL=meta/llama-3.1-70b-instruct
